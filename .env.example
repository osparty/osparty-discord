# The bot's runtime environment. In production these are the keys of the `osparty-discord-env`
# secret in the cluster's `osparty` namespace (injected via envFrom; see k8s/deployment.yaml):
#     kubectl -n osparty create secret generic osparty-discord-env --from-env-file=.env
# For local development, export them before `./gradlew bootRun`. Never commit real values.

# Shared secret for BOTH internal directions: the API's voice calls in (X-Internal-Token header),
# and this service's badge pushes out to the API. Must match DISCORD_INTERNAL_TOKEN on the API side.
# Generate one with: openssl rand -hex 32
DISCORD_INTERNAL_TOKEN=change-me-to-a-long-random-string

# Bot token from the Discord Developer Portal (Bot -> Reset Token).
DISCORD_TOKEN=your-bot-token-here

# The guild the bot operates in, and the category new party channels are created under.
# Discord snowflake ids (enable Developer Mode, right-click -> Copy ID).
DISCORD_GUILD_ID=000000000000000000
DISCORD_CATEGORY_ID=000000000000000000

# Invite lifetime (seconds) and max uses (0 = unlimited).
DISCORD_INVITE_MAX_AGE_SECONDS=86400
DISCORD_INVITE_MAX_USES=0

# Badge sync: guild roles that earn a badge next to party hosts in the plugin (snowflake ids,
# 0/unset = not mapped). Requires the privileged GUILD_MEMBERS intent (Developer Portal ->
# Bot -> Privileged Gateway Intents -> Server Members Intent), and OSPARTY_API_URL below.
DISCORD_ROLE_DEVELOPER=0
DISCORD_ROLE_CONTENT_CREATOR=0
DISCORD_ROLE_BETA_TESTER=0
DISCORD_ROLE_BACKER=0

# Base URL the bot pushes badge state to. In the cluster: http://osparty-api:8080.
# Blank disables badge sync. Authenticated with DISCORD_INTERNAL_TOKEN above.
OSPARTY_API_URL=
